# Leave OPENAI_API_KEY empty to run fully offline in deterministic mock mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Job discovery ---
# Free ATS sources (Greenhouse/Lever/Ashby + SimplifyJobs) always run and need
# NO token. The Apify LinkedIn actor is slow (minutes) and exceeds serverless
# timeouts, so it is OFF by default. Turn it on only on a long-timeout host.
ENABLE_APIFY=false
APIFY_TOKEN=
APIFY_LINKEDIN_ACTOR=curious_coder/linkedin-jobs-scraper

# --- Database ---
# Local dev: SQLite. Production: set a Postgres URL for PERSISTENCE.
# On Vercel Postgres, POSTGRES_URL is injected automatically and picked up
# (postgres:// is auto-rewritten to postgresql+psycopg2://). SQLite on serverless
# is EPHEMERAL and resets between requests — do not use it in production.
DATABASE_URL=sqlite:///./applywise.db

# Comma-separated list of allowed CORS origins (in addition to chrome-extension://*).
CORS_ORIGINS=http://localhost:5173
